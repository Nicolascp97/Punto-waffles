{
  "buildCommand": "cd landing-menu && npm ci && npm run build",
  "devCommand": "cd landing-menu && npm run dev",
  "installCommand": "cd landing-menu && npm ci",
  "framework": "vite",
  "outputDirectory": "landing-menu/dist",
  "public": true,
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
